{
  "name": "@zakkster/lite-bmfont",
  "version": "1.2.0",
  "description": "Zero-GC bitmap font canvas renderer. O(1) kerning via 64K Int16 LUT, multi-line alignment, zero-alloc numeric HUD output, and pre-laid-out wrapped text with H/V alignment + ellipsis.",
  "author": "Zahary Shinikchiev <shinikchiev@yahoo.com>",
  "license": "MIT",
  "type": "module",
  "main": "./BitmapFont.js",
  "types": "./BitmapFont.d.ts",
  "exports": {
    ".": {
      "import": "./BitmapFont.js",
      "types": "./BitmapFont.d.ts"
    }
  },
  "files": [
    "BitmapFont.js",
    "BitmapFont.d.ts",
    "llms.txt"
  ],
  "keywords": [
    "bmfont",
    "bitmap-font",
    "canvas",
    "canvas2d",
    "text",
    "text-rendering",
    "kerning",
    "word-wrap",
    "text-wrap",
    "alignment",
    "ellipsis",
    "hud",
    "game-text",
    "zero-gc",
    "zero-alloc",
    "typed-array"
  ],
  "sideEffects": false,
  "homepage": "https://github.com/PeshoVurtoleta/lite-bmfont#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeshoVurtoleta/lite-bmfont.git"
  },
  "bugs": {
    "url": "https://github.com/PeshoVurtoleta/lite-bmfont/issues",
    "email": "shinikchiev@yahoo.com"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "bundle-check": "npx esbuild BitmapFont.js --bundle --format=esm --outfile=test-bundle.js",
    "prepublishOnly": "npm run test && npm run bundle-check"
  }
}
